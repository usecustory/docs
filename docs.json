{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Custory Docs",
  "description": "Documentation for Custory, the operating system for customer journeys.",
  "colors": {
    "primary": "#0e8d00",
    "light": "#0e8d00",
    "dark": "#0e8d00"
  },
  "appearance": {
    "default": "system"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:image": "/logo/ogimage.jpg",
      "twitter:image": "/logo/ogimage.jpg"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "quickstart",
              "workspace",
              "team-management",
              "billing-and-usage",
              "core-concepts"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "faq",
              "glossary"
            ]
          }
        ]
      },
      {
        "tab": "Journey editor",
        "icon": "route",
        "groups": [
          {
            "group": "Journeys and context",
            "pages": [
              "journeys",
              "journey-templates",
              "ai-journey-imports",
              "nested-journeys",
              "journey-editor",
              "editor-controls",
              "journey-settings",
              "search-and-filters",
              "items",
              "item-fields",
              "item-linking",
              "touchpoints",
              "insights",
              "opportunities",
              "solutions",
              "metrics",
              "rich-item-details",
              "personas",
              "persona-detail-editing",
              "persona-linking",
              "views-and-priorities",
              "journey-view",
              "table-view",
              "impact-vs-effort-view",
              "version-history",
              "collaboration-and-history"
            ]
          }
        ]
      },
      {
        "tab": "AI & automations",
        "icon": "sparkles",
        "groups": [
          {
            "group": "AI workflows",
            "pages": [
              "ai-and-automations",
              "ai-workspace-member",
              "workspace-memory",
              "automations",
              "automation-triggers",
              "automation-filters",
              "automation-actions",
              "build-automations-with-ai",
              "automation-templates",
              "notifications",
              "notification-delivery-setup"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "icon": "plug",
        "groups": [
          {
            "group": "Connected tools",
            "pages": [
              "integrations",
              "github-integration",
              "posthog-and-stripe",
              "external-tasks",
              "slack-discord-ai-threads",
              "mcp-server"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://usecustory.com",
          "icon": "/icons/website.svg",
          "color": {
            "light": "#EBEBEB",
            "dark": "#1D1D1D"
          }
        },
        {
          "anchor": "Discord Community",
          "href": "https://discord.gg/B9pA8YuVf6",
          "icon": "/icons/discord.svg",
          "color": {
            "light": "#0E8D00",
            "dark": "#15D90B"
          }
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "icon": "/icons/discord.svg",
        "href": "https://discord.gg/B9pA8YuVf6"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.usecustory.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usecustory",
      "discord": "https://discord.gg/B9pA8YuVf6",
      "linkedin": "https://www.linkedin.com/company/usecustory",
      "github": "https://github.com/usecustory/docs"
    }
  }
}
