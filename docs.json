{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Custory Docs",
  "colors": {
    "primary": "#0E8D00",
    "light": "#0E8D00",
    "dark": "#15D90B"
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#2B2B2B"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "Use Custory",
            "pages": [
              "journeys",
              "items",
              "personas",
              "views-and-priorities",
              "ai-and-automations",
              "integrations"
            ]
          },
          {
            "group": "Team basics",
            "pages": [
              "workspace",
              "faq",
              "glossary"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://usecustory.com",
          "icon": "/icons/website.svg",
          "color": {
            "light": "#EBEBEB",
            "dark": "#1D1D1D"
          }
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/B9pA8YuVf6",
          "icon": "/icons/discord.svg",
          "color": {
            "light": "#0E8D00",
            "dark": "#15D90B"
          }
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "type": "discord",
        "icon": "/icons/discord.svg",
        "href": "https://discord.gg/B9pA8YuVf6"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Custory",
      "href": "https://app.usecustory.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usecustory",
      "discord": "https://discord.gg/B9pA8YuVf6",
      "linkedin": "https://www.linkedin.com/company/usecustory",
      "github": "https://github.com/usecustory/docs"
    }
  }
}
