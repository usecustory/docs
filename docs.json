{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Custory Docs",
  "colors": {
    "primary": "#0e8d00",
    "light": "#0e8d00",
    "dark": "#0e8d00"
  },
  "appearance": {
    "default": "system"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Journey editor",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "quickstart",
              "core-concepts",
              "workspace"
            ]
          },
          {
            "group": "Journeys and context",
            "pages": [
              "journeys",
              "journey-editor",
              "items",
              "personas",
              "views-and-priorities",
              "journey-view",
              "table-view",
              "impact-vs-effort-view",
              "collaboration-and-history"
            ]
          }
        ]
      },
      {
        "tab": "AI & automations",
        "groups": [
          {
            "group": "AI workflows",
            "pages": [
              "ai-and-automations",
              "automations",
              "notifications"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Connected tools",
            "pages": [
              "integrations",
              "mcp-server"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "faq",
              "glossary"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://usecustory.com",
          "icon": "/icons/website.svg",
          "color": {
            "light": "#EBEBEB",
            "dark": "#1D1D1D"
          }
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/B9pA8YuVf6",
          "icon": "/icons/discord.svg",
          "color": {
            "light": "#0E8D00",
            "dark": "#15D90B"
          }
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Community & Support",
        "icon": "/icons/discord.svg",
        "href": "https://discord.gg/B9pA8YuVf6"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Custory",
      "href": "https://app.usecustory.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usecustory",
      "discord": "https://discord.gg/B9pA8YuVf6",
      "linkedin": "https://www.linkedin.com/company/usecustory",
      "github": "https://github.com/usecustory/docs"
    }
  }
}
