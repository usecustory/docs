{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Custory Docs",
  "colors": {
    "primary": "#111111",
    "light": "#3F3F3F",
    "dark": "#F5F5F5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "Use Custory",
            "pages": [
              "journeys",
              "items",
              "personas",
              "views-and-priorities",
              "ai-and-automations",
              "integrations"
            ]
          },
          {
            "group": "Team basics",
            "pages": [
              "workspace",
              "faq",
              "glossary"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.usecustory.com",
          "icon": "arrow-up-right"
        },
        {
          "anchor": "Website",
          "href": "https://usecustory.com",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@usecustory.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Custory",
      "href": "https://app.usecustory.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usecustory",
      "linkedin": "https://www.linkedin.com/company/usecustory",
      "github": "https://github.com/flpsnd/docs"
    }
  }
}
